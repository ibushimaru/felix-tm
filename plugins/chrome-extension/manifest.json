{
  "manifest_version": 3,
  "name": "Felix TM",
  "version": "0.1.0",
  "description": "Translation Memory for Google Sheets & Excel Online — real-time fuzzy matching",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "identity",
    "contextMenus",
    "sidePanel"
  ],
  "host_permissions": [
    "https://docs.google.com/spreadsheets/*",
    "https://sheets.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "429083959906-70usbck7jmid93l2f76671ig0jpk7jdg.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://docs.google.com/spreadsheets/*"],
      "js": ["felix-engine.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [{
    "resources": ["felix-engine.js"],
    "matches": ["https://docs.google.com/*"]
  }],
  "action": {
    "default_title": "Felix TM",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
